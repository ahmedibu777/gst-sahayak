# GST Sahayak — LLM Provider Keys
# Copy to .env and add ANY combination of keys (1, 2, or all)
# LLM_PROVIDER=auto tries every configured provider until one succeeds

LLM_PROVIDER=auto

# --- OpenRouter (one key → many models) ---
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini

# --- OpenAI ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Google Gemini ---
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# --- Groq (fast, free tier) ---
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# --- DeepSeek ---
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat

# --- Anthropic Claude ---
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-3-5-haiku-latest

# --- Grok (x.ai) ---
# GROK_API_KEY=
# GROK_MODEL=grok-beta

# --- Mistral AI ---
# MISTRAL_API_KEY=
# MISTRAL_MODEL=mistral-small-latest

# --- Together AI ---
# TOGETHER_API_KEY=
# TOGETHER_MODEL=meta-llama/Meta-Llama-3-8B-Instruct-Turbo

# --- Hugging Face ---
# HF_TOKEN=
# HF_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# --- Perplexity ---
# PERPLEXITY_API_KEY=
# PERPLEXITY_MODEL=sonar

# --- Fireworks AI ---
# FIREWORKS_API_KEY=
# FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct

# --- Cohere ---
# COHERE_API_KEY=
# COHERE_MODEL=command-r-plus-08-2024

# --- Moonshot (Kimi) ---
# MOONSHOT_API_KEY=
# MOONSHOT_MODEL=moonshot-v1-8k

# --- Zhipu GLM ---
# ZHIPU_API_KEY=
# ZHIPU_MODEL=glm-4-flash

# --- SiliconFlow ---
# SILICONFLOW_API_KEY=
# SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V2.5

# --- AI21 Labs ---
# AI21_API_KEY=
# AI21_MODEL=jamba-1.5-mini

# --- Azure OpenAI ---
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# --- Ollama (local, free) ---
# OLLAMA_ENABLED=true
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

STREAMLIT_SERVER_PORT=8501